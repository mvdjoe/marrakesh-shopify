<div id="mvd-popup" class="mvd-popup-wrapper">
  <div class="mvd-popup-content">
    <div class="mvd-popup-close-btn">&times;</div>
    <div class="mvd-popup-inner">
      {% if section.settings.image != blank %}
        <div class="mvd-popup-image-container">
          <img src="{{ section.settings.image | img_url: '1024x1024' }}" alt="{{ section.settings.title | escape }}">
        </div>
      {% endif %}
      <div class="mvd-popup-text-container">
        {% if section.settings.title != blank %}
          <h2>{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.subtitle != blank %}
          <div class="subtitle-text">{{ section.settings.subtitle }}</div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const popup = document.getElementById('mvd-popup');
    const closeBtn = document.querySelector('.mvd-popup-close-btn');

    // Only proceed if the popup is set to be visible.
    {% if section.settings.frequency != 'never' %}
      {% if section.settings.frequency == 'always' %}
        // Show popup on every page refresh.
        popup.style.display = 'flex';
      {% else %}
        // Show popup once per session.
        const hasShown = sessionStorage.getItem('mvd-popup-shown');
        if (!hasShown) {
          popup.style.display = 'flex';
          sessionStorage.setItem('mvd-popup-shown', 'true');
        }
      {% endif %}
    {% endif %}

    // Close the popup when the close button is clicked.
    closeBtn.addEventListener('click', function() {
      popup.style.display = 'none';
    });
  });
</script>


{%- if section.settings.animation != blank -%}
  <script>
    (function(){
      var sectionEl = document.getElementById('shopify-section-{{ section.id }}');
      if (sectionEl) {
        {% if section.settings.animation == 'parallax' %}
          sectionEl.setAttribute('data-mvd-premium-parallax', 'true');
        {% else %}
          sectionEl.setAttribute('data-aos', '{{ section.settings.animation }}');
        {% endif %}
      }
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "MVD Pop-up",
  "tag": "section",
  "class": "section-mvd-popup",
  "settings": [
    {
      "type": "select",
      "id": "animation",
      "label": "Seleccionar Animación",
      "default": "fade-up",
      "options": [
        {
          "value": "",
          "label": "None"
        },
        {
          "value": "fade",
          "label": "Fade"
        },
        {
          "value": "fade-up",
          "label": "Fade Up"
        },
        {
          "value": "fade-down",
          "label": "Fade Down"
        },
        {
          "value": "zoom-in",
          "label": "Zoom In"
        },
        {
          "value": "zoom-out",
          "label": "Zoom Out"
        },
        {
          "value": "parallax",
          "label": "Parallax Scrolling"
        }
      ]
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen del pop-up"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "¡10% EN TU COMPRA!"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "<p>Suscríbete y recibe un 10% de descuento de regalo en tu primera compra.</p>"
    },
    {
      "type": "select",
      "id": "frequency",
      "label": "Frecuencia de aparición",
      "options": [
        {
          "value": "always",
          "label": "Siempre (en cada recarga)"
        },
        {
          "value": "once_per_session",
          "label": "Una vez por sesión"
        },
        {
          "value": "never",
          "label": "No visible"
        }
      ],
      "default": "always"
    }
  ],
  "presets": [
    {
      "name": "MVD Pop-up"
    }
  ]
}
{% endschema %}

<style>
  .mvd-popup-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.7);
    justify-content: center;
    align-items: center;
    z-index: 1000;
    display: none; /* Añadido para ocultarlo por defecto */
  }

  .mvd-popup-content {
    background-color: #fff;
    border-radius: 10px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    max-width: 700px;
    max-height: 80vh;
    overflow: hidden;
    position: relative;
    animation: fadeIn 0.5s ease-in-out;
    display: flex;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .mvd-popup-inner {
    display: flex;
    align-items: stretch;
    height: 100%;
    width: 100%;
  }

  .mvd-popup-image-container {
    flex: 1;
    display: flex;
    height: 100%;
  }

  .mvd-popup-image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 8px 0 0 8px;
  }

  .mvd-popup-text-container {
    flex: 1;
    padding: 30px;
    text-align: center;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  
  .mvd-popup-close-btn {
    position: absolute;
    top: 10px;
    right: 10px;
    font-size: 25px;
    color: #fff;
    cursor: pointer;
    background: #000;
    border-radius: 50%;
    width: 25px;
    height: 25px;
    display: flex;
    justify-content: center;
    align-items: center;
    line-height: 1;
    z-index: 1;
  }

  .mvd-popup-text-container h2 {
    font-size: 24px;
    font-weight: 700;
    margin-top: 0;
    color: #000;
    text-transform: uppercase;
  }

  .mvd-popup-text-container .subtitle-text p {
    font-size: 16px;
    color: #555;
    line-height: 1.5;
  }
  
  /* Mobile Styles */
  @media (max-width: 768px) {
    .mvd-popup-content {
      max-width: 90%;
      flex-direction: column;
      padding: 0;
    }
    .mvd-popup-inner {
      flex-direction: column;
    }
    .mvd-popup-image-container {
      width: 100%;
      height: 250px;
      border-radius: 10px 10px 0 0;
    }
    .mvd-popup-image-container img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 10px 10px 0 0;
    }
    .mvd-popup-text-container {
      padding: 15px;
      margin: 0 10px; /* Margen horizontal añadido para el texto */
    }
    .mvd-popup-close-btn {
      top: 5px;
      right: 5px;
      color: #fff;
      background: rgba(0, 0, 0, 0.5);
    }
    .mvd-popup-text-container h2 {
      font-size: 20px;
    }
    .mvd-popup-text-container .subtitle-text p {
      font-size: 14px;
    }
  }
</style>