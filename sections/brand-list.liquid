<!-- brand-list.liquid -->
<div class="customstyle{{ section.id }} " data-aos="{{ section.settings.animation }}" >
  {%- render 'style-section' -%}
  <div class="{{ section.settings.setwidth }}">
    <div class="section-block">
      {%- render 'section-heading' -%}
      <div class=" row">
        {%- for block in section.blocks -%}
        <div class=" col-6 col-md-{{ section.settings.width }} d-flex justify-content-center align-items-center my-4" {{ block.shopify_attributes }} data-aos="{{ section.settings.animation }}" data-aos-duration="1200">
          <div class="flex__item text-center">
            <div class="image-block">
              {%- if block.settings.image != blank -%}
              <a href="{{ block.settings.link | default: '#' }}" class="{%- if section.settings.grayscale -%}hv-image-grayscale{%- endif -%}">
                <img src="{{ block.settings.image | image_url: width: 250 }}" 
                  alt="{{ block.settings.image.alt }}" class="image-block__image"
                  loading="lazy"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                >
              </a>
              {%- else -%}
              <div class="image-block__image">
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
              {%- endif -%}
            </div>
          </div>
        </div>
        {%- endfor -%}
      </div>

      {%- if section.blocks.size == 0 -%}
      {%- render 'no-blocks' -%}
      {%- endif -%}
    </div>
  </div>
</div>

{%- if section.settings.animation != blank -%}
  <script>
    (function(){
      var sectionEl = document.getElementById('shopify-section-{{ section.id }}');
      if (sectionEl) {
        {% if section.settings.animation == 'parallax' %}
          sectionEl.setAttribute('data-mvd-premium-parallax', 'true');
        {% elsif section.settings.animation == 'sticky-reveal' %}
          sectionEl.setAttribute('data-mvd-sticky-reveal', 'true');
        {% else %}
          sectionEl.setAttribute('data-aos', '{{ section.settings.animation }}');
        {% endif %}
      }
    })();
  </script>
{%- endif -%}

