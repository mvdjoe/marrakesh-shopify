{% comment %}
  mvd-before-after.liquid
  Section for a before-and-after image comparison slider with an interactive handle and aspect ratio control.
{% endcomment %}

{%- liquid
  assign before_image = section.settings.before_image
  assign after_image = section.settings.after_image
  assign before_label = section.settings.before_label
  assign after_label = section.settings.after_label
  assign handle_color = section.settings.handle_color
  assign section_height = section.settings.section_height
  assign section_height_mb = section.settings.section_height_mb
  assign container_width = section.settings.container_width
  assign image_ratio = section.settings.image_ratio
-%}

<style>
  #mvd-ba-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .mvd-ba-container {
    position: relative;
    width: 100%;
    overflow: hidden;
    user-select: none;
    background-color: #f5f5f5;
  }

  /* Aspect Ratio Logic */
  .mvd-ba-container.ratio-natural {
    height: {{ section_height }}px;
  }
  .mvd-ba-container.ratio-square { aspect-ratio: 1 / 1; height: auto; }
  .mvd-ba-container.ratio-portrait { aspect-ratio: 2 / 3; height: auto; }
  .mvd-ba-container.ratio-landscape { aspect-ratio: 4 / 3; height: auto; }
  .mvd-ba-container.ratio-four-five { aspect-ratio: 4 / 5; height: auto; }

  @media (max-width: 767px) {
    .mvd-ba-container.ratio-natural {
      height: {{ section_height_mb }}px;
    }
  }

  .mvd-ba-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }

  /* The 'Before' image is the top one, we'll clip it */
  .mvd-ba-before {
    z-index: 2;
    clip-path: inset(0 50% 0 0); /* Initial state: 50% width */
  }

  .mvd-ba-after {
    z-index: 1;
  }

  /* Handle / Divider */
  .mvd-ba-handle {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 2px;
    background-color: {{ handle_color }};
    z-index: 3;
    cursor: ew-resize;
    transform: translateX(-50%);
  }

  .mvd-ba-handle-circle {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 44px;
    height: 44px;
    background-color: #ffffff;
    border: 2px solid {{ handle_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 15px rgba(0,0,0,0.15);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .mvd-ba-handle:hover .mvd-ba-handle-circle {
    transform: translate(-50%, -50%) scale(1.1);
    box-shadow: 0 0 20px rgba(0,0,0,0.2);
  }

  /* Si el color del tirador es muy claro, forzamos las flechas a ser negras para visibilidad */
  .mvd-ba-handle-arrows {
    display: flex;
    gap: 8px;
    color: {% if handle_color == '#ffffff' or handle_color == '#FFFFFF' %}#000000{% else %}{{ handle_color }}{% endif %};
  }

  .mvd-ba-handle-arrows svg {
    width: 12px;
    height: 12px;
  }

  /* Labels */
  .mvd-ba-label {
    position: absolute;
    bottom: 20px;
    padding: 8px 16px;
    background-color: rgba(255, 255, 255, 0.8);
    color: #000000;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 500;
    z-index: 4;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .mvd-ba-container:hover .mvd-ba-label {
    opacity: 1;
  }

  .mvd-ba-label-before {
    left: 20px;
  }

  .mvd-ba-label-after {
    right: 20px;
  }

  .mvd-ba-image-wrapper {
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
  }

  .mvd-ba-image-wrapper svg {
    width: 100%;
    height: 100%;
    background-color: #eee;
  }
</style>

<div id="mvd-ba-{{ section.id }}" class="mvd-before-after-section">
  <div class="{{ container_width }}">
    <div class="mvd-ba-container ratio-{{ image_ratio }}" id="mvd-ba-container-{{ section.id }}">
      
      {% comment %} After Image (Base) {% endcomment %}
      <div class="mvd-ba-image-wrapper mvd-ba-after">
        {%- if after_image != blank -%}
          {{ after_image | image_url: width: 2000 | image_tag: class: 'mvd-ba-image', loading: 'lazy' }}
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
        {%- if after_label != blank -%}
          <span class="mvd-ba-label mvd-ba-label-after">{{ after_label }}</span>
        {%- endif -%}
      </div>

      {% comment %} Before Image (Overlay) {% endcomment %}
      <div class="mvd-ba-image-wrapper mvd-ba-before" id="mvd-ba-before-{{ section.id }}">
        {%- if before_image != blank -%}
          {{ before_image | image_url: width: 2000 | image_tag: class: 'mvd-ba-image', loading: 'lazy' }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
        {%- if before_label != blank -%}
          <span class="mvd-ba-label mvd-ba-label-before">{{ before_label }}</span>
        {%- endif -%}
      </div>

      {% comment %} Handle {% endcomment %}
      <div class="mvd-ba-handle" id="mvd-ba-handle-{{ section.id }}">
        <div class="mvd-ba-handle-circle">
          <div class="mvd-ba-handle-arrows">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  (function() {
    function initBeforeAfter() {
      const container = document.getElementById('mvd-ba-container-{{ section.id }}');
      const beforeImage = document.getElementById('mvd-ba-before-{{ section.id }}');
      const handle = document.getElementById('mvd-ba-handle-{{ section.id }}');
      
      if (!container || !beforeImage || !handle) return;

      let isDragging = false;

      function updatePosition(x) {
        const rect = container.getBoundingClientRect();
        let position = ((x - rect.left) / rect.width) * 100;
        
        // Boundaries
        if (position < 0) position = 0;
        if (position > 100) position = 100;

        beforeImage.style.clipPath = `inset(0 ${100 - position}% 0 0)`;
        handle.style.left = `${position}%`;
      }

      // Mouse Events
      container.addEventListener('mousedown', (e) => {
        isDragging = true;
        updatePosition(e.clientX);
      });

      window.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        updatePosition(e.clientX);
      });

      window.addEventListener('mouseup', () => {
        isDragging = false;
      });

      // Touch Events
      container.addEventListener('touchstart', (e) => {
        isDragging = true;
        if (e.touches && e.touches[0]) {
          updatePosition(e.touches[0].clientX);
        }
      }, { passive: true });

      window.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        if (e.touches && e.touches[0]) {
          updatePosition(e.touches[0].clientX);
        }
      }, { passive: false });

      window.addEventListener('touchend', () => {
        isDragging = false;
      });
    }

    // Initialize on load and Shopify Editor events
    document.addEventListener('DOMContentLoaded', initBeforeAfter);
    if (window.Shopify && window.Shopify.designMode) {
      document.addEventListener('shopify:section:load', initBeforeAfter);
    } else {
      initBeforeAfter();
    }
  })();
</script>

{% schema %}
{
  "name": "MVD Before/After",
  "settings": [
    {
      "type": "header",
      "content": "Imágenes de Comparación"
    },
    {
      "type": "image_picker",
      "id": "before_image",
      "label": "Imagen de ANTES (Izquierda)"
    },
    {
      "type": "text",
      "id": "before_label",
      "label": "Etiqueta Antes",
      "default": "Antes"
    },
    {
      "type": "image_picker",
      "id": "after_image",
      "label": "Imagen de DESPUÉS (Derecha)"
    },
    {
      "type": "text",
      "id": "after_label",
      "label": "Etiqueta Después",
      "default": "Después"
    },
    {
      "type": "header",
      "content": "Ajustes de Diseño"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Ancho del contenedor",
      "default": "container-fluid",
      "options": [
        { "value": "container", "label": "Centrado (Page Width)" },
        { "value": "container-fluid", "label": "Ancho Total" }
      ]
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Relación de aspecto de imagen",
      "default": "natural",
      "options": [
        { "value": "natural", "label": "Altura Personalizada" },
        { "value": "square", "label": "Cuadrado (1:1)" },
        { "value": "portrait", "label": "Retrato (2:3)" },
        { "value": "landscape", "label": "Paisaje (4:3)" },
        { "value": "four-five", "label": "Vertical (4:5)" }
      ]
    },
    {
      "type": "range",
      "id": "section_height",
      "min": 300,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "label": "Altura Personalizada (Desktop)",
      "default": 600,
      "info": "Solo funciona si 'Relación de aspecto' es 'Altura Personalizada'"
    },
    {
      "type": "range",
      "id": "section_height_mb",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Altura Personalizada (Móvil)",
      "default": 400,
      "info": "Solo funciona si 'Relación de aspecto' es 'Altura Personalizada'"
    },
    {
      "type": "color",
      "id": "handle_color",
      "label": "Color del Tirador",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Espaciado de Sección"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Superior",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Inferior",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "MVD Before/After"
    }
  ]
}
{% endschema %}
