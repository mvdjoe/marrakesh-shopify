<!-- line.liquid -->
<style>
    .customstyle{{ section.id }} .border-custom{
        border-top-width: {{ section.settings.wborder }} !important;
        border-color: {{ section.settings.bgborder }} !important;
    }
</style>
<div class="customstyle{{ section.id }}" data-aos="{{ section.settings.animation }}">
    {%- render 'style-section' -%}
    <div class="{{ section.settings.setwidth }}">
      <div class="border-top border-custom">
      </div>
    </div>
  </div>
  
{%- if section.settings.animation != blank -%}
  <script>
    (function(){
      var sectionEl = document.getElementById('shopify-section-{{ section.id }}');
      if (sectionEl) {
        {% if section.settings.animation == 'parallax' %}
          sectionEl.setAttribute('data-mvd-premium-parallax', 'true');
        {% elsif section.settings.animation == 'sticky-reveal' %}
          sectionEl.setAttribute('data-mvd-sticky-reveal', 'true');
        {% else %}
          sectionEl.setAttribute('data-aos', '{{ section.settings.animation }}');
        {% endif %}
      }
    })();
  </script>
{%- endif -%}

{% schema %}

{
  "name": "Divider",
  "class": "index-section",
  "settings": [
    {
      "type": "select",
      "id": "animation",
      "label": "Seleccionar Animación",
      "default": "fade-up",
      "options": [
        {
          "value": "",
          "label": "None"
        },
        {
          "value": "fade",
          "label": "Fade"
        },
        {
          "value": "fade-up",
          "label": "Fade Up"
        },
        {
          "value": "fade-down",
          "label": "Fade Down"
        },
        {
          "value": "zoom-in",
          "label": "Zoom In"
        },
        {
          "value": "zoom-out",
          "label": "Zoom Out"
        },
        {
          "value": "parallax",
          "label": "Parallax Scrolling (Slide Over)"
        },
        {
          "value": "sticky-reveal",
          "label": "Sticky Footer Reveal (Curtain)"
        }
      ]
    },
    {
      "type": "text",
      "id": "paddingsection",
      "label": "Section padding",
      "default": "0px 0px 0px 0px",
      "info": "Padding: Top Right Bottom Left"
    },
    {
      "type": "text",
      "id": "marginsection",
      "label": "Margin Section",
      "default": "0px 0px 0px 0px",
      "info": "Margin: Top Right Bottom Left"
    },
    {
      "type": "color",
      "id": "bgsection",
      "label": "Background Section",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "setwidth",
      "label": "Full Width",
      "default": "container",
      "options": [
        {
          "value": "container",
          "label": "Box"
        },
        {
          "value": "container-fluid",
          "label": "Container Fluid"
        },
        {
          "value": "full",
          "label": "Full"
        }
      ]
    },
    {
      "type": "color",
      "id": "bgborder",
      "label": "Border Divider",
      "default": "#dddddd"
    },
    {
      "type": "text",
      "id": "wborder",
      "label": "Width Border",
      "default": "1px"
    }
  ],
  "presets": [
    {
      "name": "Divider",
      "category": "Advanced layout"
    }
  ]
}

{% endschema %}
  