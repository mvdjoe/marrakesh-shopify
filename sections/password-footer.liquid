<!-- password-footer.liquid -->
{% comment %}
Share homepage URL
Shared text is from the store meta description
{% endcomment %}
{% if section.settings.show_share_buttons %}
	<div class="password-social-sharing">
		<p class="h6 text-white mb-2">{{ section.settings.social_message | escape }}</p>
		{% render 'social-sharing', center_icons: true, share_title: shop.password_message %}
	</div>
{% endif %}

<footer class="password-footer" role="contentinfo">
	{% capture shopify %}
	<a href="//www.shopify.com" target="_blank" title="Create your own online store with Shopify">
		{% render 'icon-shopify-logo' %}
		<span class="visually-hidden">Shopify</span>
	</a>
	{% endcapture %}
	{{ 'general.password_page.powered_by_shopify_html' | t: shopify: shopify }}
</footer>


{%- if section.settings.animation != blank -%}
  <script>
    (function(){
      var sectionEl = document.getElementById('shopify-section-{{ section.id }}');
      if (sectionEl) {
        {% if section.settings.animation == 'parallax' %}
          sectionEl.setAttribute('data-mvd-premium-parallax', 'true');
        {% elsif section.settings.animation == 'sticky-reveal' %}
          sectionEl.setAttribute('data-mvd-sticky-reveal', 'true');
        {% else %}
          sectionEl.setAttribute('data-aos', '{{ section.settings.animation }}');
        {% endif %}
      }
    })();
  </script>
{%- endif -%}

{% schema %}

{
  "name": "Footer",
  "settings": [
    {
      "type": "select",
      "id": "animation",
      "label": "Seleccionar Animación",
      "default": "fade-up",
      "options": [
        {
          "value": "",
          "label": "None"
        },
        {
          "value": "fade",
          "label": "Fade"
        },
        {
          "value": "fade-up",
          "label": "Fade Up"
        },
        {
          "value": "fade-down",
          "label": "Fade Down"
        },
        {
          "value": "zoom-in",
          "label": "Zoom In"
        },
        {
          "value": "zoom-out",
          "label": "Zoom Out"
        },
        {
          "value": "parallax",
          "label": "Parallax Scrolling (Slide Over)"
        },
        {
          "value": "sticky-reveal",
          "label": "Sticky Footer Reveal (Curtain)"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_share_buttons",
      "label": "Show social sharing buttons",
      "default": true
    },
    {
      "type": "text",
      "id": "social_message",
      "label": "Social sharing buttons heading",
      "default": "Spread the word"
    }
  ]
}

{% endschema %}
