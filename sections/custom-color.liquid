<style>
    
        {%- for block in section.blocks -%}
            {%- liquid 
                assign name_color = block.settings.name_color | handle
                assign name_color_hex = block.settings.name_color_hex
                assign image_color = block.settings.image_color
                -%}
            {%- if name_color != blank -%}
                .st-color-{{ name_color }}{
                    {%- if image_color != blank -%}
                    background-image:{%- if image_color != blank -%} url({{ image_color | image_url: width: 64 }}) {%- else -%} inherit !important {%- endif -%};
                    {%- else -%}
                    background-color: {{ name_color_hex }} !important;
                    {%- endif -%}
                }
            {%- endif -%}
        {%- endfor -%}   

</style>


{%- if section.settings.animation != blank -%}
  <script>
    (function(){
      var sectionEl = document.getElementById('shopify-section-{{ section.id }}');
      if (sectionEl) {
        {% if section.settings.animation == 'parallax' %}
          sectionEl.setAttribute('data-mvd-premium-parallax', 'true');
        {% elsif section.settings.animation == 'sticky-reveal' %}
          sectionEl.setAttribute('data-mvd-sticky-reveal', 'true');
        {% else %}
          sectionEl.setAttribute('data-aos', '{{ section.settings.animation }}');
        {% endif %}
      }
    })();
  </script>
{%- endif -%}

{% schema %}

{
  "name": "Custom color Filter",
  "class": "custom_color",
  "settings": [
    {
      "type": "select",
      "id": "animation",
      "label": "Seleccionar Animación",
      "default": "fade-up",
      "options": [
        {
          "value": "",
          "label": "None"
        },
        {
          "value": "fade",
          "label": "Fade"
        },
        {
          "value": "fade-up",
          "label": "Fade Up"
        },
        {
          "value": "fade-down",
          "label": "Fade Down"
        },
        {
          "value": "zoom-in",
          "label": "Zoom In"
        },
        {
          "value": "zoom-out",
          "label": "Zoom Out"
        },
        {
          "value": "parallax",
          "label": "Parallax Scrolling (Slide Over)"
        },
        {
          "value": "sticky-reveal",
          "label": "Sticky Footer Reveal (Curtain)"
        }
      ]
    },
    {
      "type": "header",
      "content": "Customize color ",
      "info": "This color help you customize color for filter and variant swatch product"
    }
  ],
  "blocks": [
    {
      "type": "color",
      "name": "Color & Image",
      "settings": [
        {
          "type": "text",
          "id": "name_color",
          "label": "Name Color Variant",
          "info": "This Name color variant"
        },
        {
          "type": "color",
          "id": "name_color_hex",
          "label": "Color",
          "default": "#000000"
        },
        {
          "type": "image_picker",
          "id": "image_color",
          "label": "Image"
        }
      ]
    }
  ]
}

{% endschema %}
