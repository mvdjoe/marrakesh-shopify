<!-- product-list-2.liquid -->
<div class="customstyle{{ section.id }}" data-aos="{{ section.settings.animation }}">
    {%- render 'style-section' -%}
  <div class="{{ section.settings.setwidth }}">
    <div class="section-block">
      {%- render 'section-heading' -%}
      <div class="row">
          <div class="col ">
            {%- if section.settings.descolumn != blank -%}
              {{ section.settings.descolumn }}
            {%- endif -%}
          </div>
          <div class="{{ section.settings.columnwitdh }}">
            <div class="productlist-wrapper dots-negative" data-aos="{{ section.settings.animation }}">
                <div class="productlist-slider row" id="Productlist-{{ section.id }}"
                     style="opacity:0"
                     data-rows="{{ section.settings.rows }}"
                     data-slidesToShow="{{ section.settings.show }}"
                     data-arrows="{{ section.settings.arrows }}"
                     data-dots="{{ section.settings.dots }}" 
                     data-draggable="{{ section.settings.draggable }}" 
                     data-infinite="{{ section.settings.infinite }}" 
                     data-section-id="{{ section.id }}" 
                     data-section-type="productlist">
                  {%- assign collection = collections[section.settings.collection] -%}
                  {%- assign limit = section.settings.limit -%}
                  {%- if collection != blank -%}
                  {%- for product in collection.products limit: limit -%}
                  <div class="productlist-item col">
                    {%- render 'product-card', product: product -%}
                  </div>
                  {%- endfor -%}
                  {%- else -%}
                  {%- for i in (1..limit) -%}
                  <div class="productlist-item col">
                    {%- render 'product-grid-blank' -%}
                  </div>
                  {%- endfor -%}
                  {%- endif -%}
                </div>
              </div>
          </div>
      </div>
      
    </div>
  </div>
  </div>
  
  
{%- if section.settings.animation != blank -%}
  <script>
    (function(){
      var sectionEl = document.getElementById('shopify-section-{{ section.id }}');
      if (sectionEl) {
        {% if section.settings.animation == 'parallax' %}
          sectionEl.setAttribute('data-mvd-premium-parallax', 'true');
        {% elsif section.settings.animation == 'sticky-reveal' %}
          sectionEl.setAttribute('data-mvd-sticky-reveal', 'true');
        {% else %}
          sectionEl.setAttribute('data-aos', '{{ section.settings.animation }}');
        {% endif %}
      }
    })();
  </script>
{%- endif -%}

