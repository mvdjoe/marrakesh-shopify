<style>
  .mvd-videotext-section {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: {{ section.settings.padding_left }}px;
    padding-right: {{ section.settings.padding_right }}px;
  }
  
  .mvd-videotext-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
  }

  @media (min-width: 768px) {
    .mvd-videotext-grid {
      grid-template-columns: 1fr 1fr;
      gap: 60px;
    }
  }

  .mvd-videotext-content {
    text-align: left;
  }

  .mvd-videotext-content h5 {
    font-size: 1.5rem;
    margin-bottom: 25px;
  }

  .mvd-videotext-content p {
    line-height: 1.5;
    margin-bottom: 25px;
  }
  
  .mvd-videotext-video-wrapper {
    position: relative;
    padding-top: 133.33%;
    /* Relación de aspecto 3:4 */
    overflow: hidden;
  }
  
  .mvd-videotext-video-wrapper video,
  .mvd-videotext-video-wrapper .instagram-embed-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  /* Estilos para el botón */
  .mvd-btn {
    display: inline-block;
    padding: 15px 30px;
    text-align: center;
    text-decoration: none;
    font-weight: bold;
    border-radius: 5px;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .mvd-btn--primary {
    background-color: {{ section.settings.button_bg_color_primary }};
    color: {{ section.settings.button_text_color_primary }};
    border: 2px solid {{ section.settings.button_bg_color_primary }};
  }

  .mvd-btn--primary:hover {
    background-color: transparent;
    color: {{ section.settings.button_bg_color_primary }};
  }

  .mvd-btn--secondary {
    background-color: transparent;
    color: {{ section.settings.button_text_color_secondary }};
    border: 2px solid {{ section.settings.button_text_color_secondary }};
  }

  .mvd-btn--secondary:hover {
    background-color: {{ section.settings.button_text_color_secondary }};
    color: {{ section.settings.button_bg_color_secondary }};
  }

  .mvd-btn--full-width {
    width: 100%;
  }

  /* El truco visual para Instagram: ocultar la interfaz con barras */
  .mvd-videotext-video-wrapper .instagram-embed-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .mvd-videotext-video-wrapper .instagram-embed-wrapper::before,
  .mvd-videotext-video-wrapper .instagram-embed-wrapper::after {
    content: '';
    position: absolute;
    left: 0;
    width: 100%;
    background-color: #000;
    z-index: 2;
  }

  .mvd-videotext-video-wrapper .instagram-embed-wrapper::before {
    top: 0;
    height: 25%;
  }

  .mvd-videotext-video-wrapper .instagram-embed-wrapper::after {
    bottom: 0;
    height: 25%;
  }
  
  .mvd-videotext-container {
    max-width: 1200px;
    margin: 0 auto;
    padding-left: 15px;
    padding-right: 15px;
  }
  
  .mvd-videotext-box {
    max-width: 900px;
    margin: 0 auto;
    padding: 20px;
    border: 1px solid #ddd;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }
  
  .mvd-videotext-full-width {
    padding-left: 0;
    padding-right: 0;
  }
</style>

<div class="mvd-videotext-section">
  <div class="{% case section.settings.layout %}{% when 'container' %}mvd-videotext-container{% when 'box' %}mvd-videotext-box{% else %}mvd-videotext-full-width{% endcase %}">
    <div class="mvd-videotext-grid">
      {%- if section.settings.content_position == 'left' -%}
        <div class="mvd-videotext-content">
          {% if section.settings.heading != blank %}
            <h5>{{ section.settings.heading }}</h5>
          {% endif %}
          {% if section.settings.text != blank %}
            <p>{{ section.settings.text }}</p>
          {% endif %}
          {% if section.settings.button_text != blank and section.settings.button_url != blank %}
            <a href="{{ section.settings.button_url }}" 
               class="mvd-btn 
                      {% case section.settings.button_style %}
                      {% when 'primary' %}mvd-btn--primary
                      {% when 'secondary' %}mvd-btn--secondary
                      {% endcase %}
                      {% if section.settings.button_width == 'full' %}mvd-btn--full-width{% endif %}">
              {{ section.settings.button_text }}
            </a>
          {% endif %}
        </div>
        <div class="mvd-videotext-video-wrapper">
          {%- case section.settings.video_source -%}
            {%- when 'shopify' -%}
              {% if section.settings.video_url != blank %}
                <video playsinline controls poster="{{ section.settings.poster_image | img_url: 'master' }}">
                  <source src="{{ section.settings.video_url }}" type="video/mp4">
                </video>
              {% endif %}
            {%- when 'instagram' -%}
              {% if section.settings.instagram_embed_code != blank %}
                <div class="instagram-embed-wrapper">
                  {{ section.settings.instagram_embed_code | raw }}
                </div>
              {% endif %}
          {%- endcase -%}
        </div>
      {%- else -%}
        <div class="mvd-videotext-video-wrapper">
          {%- case section.settings.video_source -%}
            {%- when 'shopify' -%}
              {% if section.settings.video_url != blank %}
                <video playsinline controls poster="{{ section.settings.poster_image | img_url: 'master' }}">
                  <source src="{{ section.settings.video_url }}" type="video/mp4">
                </video>
              {% endif %}
            {%- when 'instagram' -%}
              {% if section.settings.instagram_embed_code != blank %}
                <div class="instagram-embed-wrapper">
                  {{ section.settings.instagram_embed_code | raw }}
                </div>
              {% endif %}
          {%- endcase -%}
        </div>
        <div class="mvd-videotext-content">
          {% if section.settings.heading != blank %}
            <h5>{{ section.settings.heading }}</h5>
          {% endif %}
          {% if section.settings.text != blank %}
            <p>{{ section.settings.text }}</p>
          {% endif %}
          {% if section.settings.button_text != blank and section.settings.button_url != blank %}
            <a href="{{ section.settings.button_url }}" 
               class="mvd-btn 
                      {% case section.settings.button_style %}
                      {% when 'primary' %}mvd-btn--primary
                      {% when 'secondary' %}mvd-btn--secondary
                      {% endcase %}
                      {% if section.settings.button_width == 'full' %}mvd-btn--full-width{% endif %}">
              {{ section.settings.button_text }}
            </a>
          {% endif %}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}{
  "name": "MVD Video with Text",
  "tag": "section",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Ancho de la sección",
      "default": "container",
      "options": [
        {
          "value": "container",
          "label": "Ancho fijo (Container)"
        },
        {
          "value": "full-width",
          "label": "Ancho completo (Full width)"
        },
        {
          "value": "box",
          "label": "Caja (Box)"
        }
      ]
    },
    {
      "type": "select",
      "id": "video_source",
      "label": "Fuente del video",
      "options": [
        {
          "value": "shopify",
          "label": "Video de Shopify"
        },
        {
          "value": "instagram",
          "label": "Video de Instagram"
        }
      ],
      "default": "shopify"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "URL del video de Shopify",
      "info": "Sube tu video a 'Archivos' en Shopify y pega aquí la URL. Solo para videos de Shopify."
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Imagen de Portada",
      "info": "Selecciona una imagen para mostrar antes de que el video comience a reproducirse."
    },
    {
      "type": "html",
      "id": "instagram_embed_code",
      "label": "Código de inserción de Instagram",
      "info": "Pega aquí el código de inserción completo que obtienes de Instagram. Solo para videos de Instagram."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Title",
      "default": "Título de tu video"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Agrega un subtítulo o descripción para acompañar el video. Explica tu marca o el mensaje de esta sección.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Text button",
      "default": "Ver más"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Estilo del botón"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Estilo del botón",
      "options": [
        {
          "value": "primary",
          "label": "Primario"
        },
        {
          "value": "secondary",
          "label": "Secundario"
        }
      ],
      "default": "primary"
    },
    {
      "type": "color",
      "id": "button_bg_color_primary",
      "label": "Color de fondo (Primario)",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color_primary",
      "label": "Color de texto (Primario)",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_bg_color_secondary",
      "label": "Color de fondo (Secundario)",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color_secondary",
      "label": "Color de texto (Secundario)",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "button_width",
      "label": "Ancho del botón",
      "options": [
        {
          "value": "auto",
          "label": "Automtico"
        },
        {
          "value": "full",
          "label": "Full Width"
        }
      ],
      "default": "auto"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Posición del contenido",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Derecha"
        }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Espacio superior (Padding Top)",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Espacio inferior (Padding Bottom)",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Espacio izquierdo (Padding Left)",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Espacio derecho (Padding Right)",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "MVD Video con Texto",
      "category": "Video"
    }
  ]
}{% endschema %}