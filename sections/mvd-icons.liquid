{% comment %}
  mvd-icons.liquid
  Section for displaying category icons (e.g., jewelry types like necklaces, earrings) with labels.
{% endcomment %}

{%- liquid
  assign title_size_desktop = section.settings.title_size_desktop
  assign title_size_mobile = section.settings.title_size_mobile
  assign tint_icons = section.settings.tint_image_icons
  assign bg_color = section.settings.bg_color
  assign text_color = section.settings.text_color
  assign accent_color = section.settings.accent_color
  assign columns_desktop = section.settings.columns_desktop
  assign columns_mobile = section.settings.columns_mobile
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_top_mb = section.settings.padding_top_mb
  assign padding_bottom_mb = section.settings.padding_bottom_mb
  assign padding_left = section.settings.padding_left
  assign padding_right = section.settings.padding_right
  assign padding_left_mb = section.settings.padding_left_mb
  assign padding_right_mb = section.settings.padding_right_mb
  assign gap_desktop = section.settings.gap_desktop
  assign gap_mobile = section.settings.gap_mobile
-%}

<div id="mvd-icons-{{ section.id }}" class="mvd-icons-section">
  <div class="{{ section.settings.container_width }}">
    {% if section.settings.title != blank %}
      <div class="mvd-icons-header">
        <h2 class="mvd-icons-title" style="color: {{ text_color }}; font-size: {{ title_size_desktop }}px;">{{ section.settings.title | escape }}</h2>
      </div>
    {% endif %}

    <div class="mvd-icons-grid columns-desktop-{{ columns_desktop }} columns-mobile-{{ columns_mobile }}">
      {% for block in section.blocks %}
        <div class="mvd-icon-item" {{ block.shopify_attributes }}>
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}" class="mvd-icon-link">
          {% endif %}
          
          <div class="mvd-icon-image-wrapper">
            {% if block.settings.icon_type == 'preset' %}
              {% case block.settings.preset_icon %}
                {% when 'necklace' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v3M5 7l2 2M19 7l-2 2M4 22c0-4.4 3.6-8 8-8s8 3.6 8 8"/><circle cx="12" cy="11" r="3"/></svg>
                {% when 'earrings' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="7" cy="18" r="3"/><circle cx="17" cy="18" r="3"/><path d="M7 15V4M17 15V4M7 4h10"/></svg>
                {% when 'ring' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="7" r="5"/><path d="M7 11.5V19c0 2.8 2.2 5 5 5s5-2.2 5-5v-7.5"/></svg>
                {% when 'bracelet' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 3v18M3 12h18"/></svg>
                {% when 'watch' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="7"/><path d="M12 9v3l2 2M16 3h-8M16 21h-8"/></svg>
                {% when 'diamond' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h12l4 6-10 12L2 9zM11 3l-4 6 5 12 5-12-4-6M2 9h20"/></svg>
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endcase %}
            {% else %}
              {% if block.settings.icon != blank %}
                {% if tint_icons %}
                  <div class="mvd-icon-image-tinted" style="-webkit-mask-image: url({{ block.settings.icon | image_url: width: 200 }}); mask-image: url({{ block.settings.icon | image_url: width: 200 }}); background-color: {{ accent_color }};"></div>
                {% else %}
                  <img src="{{ block.settings.icon | image_url: width: 200 }}" 
                       alt="{{ block.settings.label | escape }}" 
                       loading="lazy"
                       class="mvd-icon-image">
                {% endif %}
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            {% endif %}
          </div>
          
          {% if block.settings.label != blank %}
            <span class="mvd-icon-label" style="color: {{ text_color }};">{{ block.settings.label | escape }}</span>
          {% endif %}

          {% if block.settings.link != blank %}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<style>
  #mvd-icons-{{ section.id }} {
    background-color: {{ bg_color }};
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
    padding-left: {{ padding_left }}px;
    padding-right: {{ padding_right }}px;
  }

  @media (max-width: 767px) {
    #mvd-icons-{{ section.id }} {
      padding-top: {{ padding_top_mb }}px;
      padding-bottom: {{ padding_bottom_mb }}px;
      padding-left: {{ padding_left_mb }}px;
      padding-right: {{ padding_right_mb }}px;
    }
    #mvd-icons-{{ section.id }} .mvd-icons-title {
      font-size: {{ title_size_mobile }}px !important;
    }
  }

  .mvd-icons-section {
    width: 100%;
  }

  .mvd-icons-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .mvd-icons-title {
    font-size: 1.5rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .mvd-icons-grid {
    display: grid;
    gap: {{ gap_desktop }}px;
    justify-items: center;
  }

  /* Desktop Columns */
  .columns-desktop-2 { grid-template-columns: repeat(2, 1fr); }
  .columns-desktop-3 { grid-template-columns: repeat(3, 1fr); }
  .columns-desktop-4 { grid-template-columns: repeat(4, 1fr); }
  .columns-desktop-5 { grid-template-columns: repeat(5, 1fr); }
  .columns-desktop-6 { grid-template-columns: repeat(6, 1fr); }
  .columns-desktop-8 { grid-template-columns: repeat(8, 1fr); }

  /* Mobile Columns */
  @media (max-width: 767px) {
    .mvd-icons-grid {
      gap: {{ gap_mobile }}px;
    }
    .columns-mobile-1 { grid-template-columns: repeat(1, 1fr); }
    .columns-mobile-2 { grid-template-columns: repeat(2, 1fr); }
    .columns-mobile-3 { grid-template-columns: repeat(3, 1fr); }
    .columns-mobile-4 { grid-template-columns: repeat(4, 1fr); }
  }

  .mvd-icon-item {
    text-align: center;
    width: 100%;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .mvd-icon-item:hover {
    transform: translateY(-8px);
  }

  .mvd-icon-link {
    text-decoration: none;
    display: block;
    color: inherit;
  }

  .mvd-icon-image-wrapper {
    width: 60px;
    height: 60px;
    margin: 0 auto 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: visible;
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .mvd-icon-item:hover .mvd-icon-image-wrapper {
    transform: scale(1.15);
  }

  .mvd-icon-image-wrapper svg {
    width: 100%;
    height: 100%;
    stroke: {{ accent_color }};
    transition: stroke 0.3s ease;
  }

  .mvd-icon-image-tinted {
    width: 100%;
    height: 100%;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-position: center;
    mask-position: center;
    transition: background-color 0.3s ease;
  }

  .mvd-icon-image {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    transition: transform 0.4s ease;
  }

  .mvd-icon-label {
    display: block;
    font-size: 0.9rem;
    font-style: italic;
    opacity: 0.7;
    transition: all 0.3s ease;
    letter-spacing: 0.05em;
  }

  .mvd-icon-item:hover .mvd-icon-label {
    opacity: 1;
    transform: translateY(2px);
  }

  .placeholder-svg {
    width: 100%;
    height: 100%;
    fill: #f0f0f0;
    background: #fafafa;
  }
</style>

{% schema %}
{
  "name": "MVD Icons",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Categorías"
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "min": 12,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Tamaño de Título Desktop",
      "default": 24
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "min": 12,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Tamaño de Título Móvil",
      "default": 18
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Ancho del contenedor",
      "default": "container",
      "options": [
        { "value": "container", "label": "Centrado" },
        { "value": "container-fluid", "label": "Ancho Total" }
      ]
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Columnas Desktop",
      "default": 6
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Columnas Móvil",
      "default": 3
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Espaciado entre iconos Desktop",
      "default": 20
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Espaciado entre iconos Móvil",
      "default": 20
    },
    {
      "type": "header",
      "content": "Colores"
    },
    {
      "type": "checkbox",
      "id": "tint_image_icons",
      "label": "Teñir iconos de imagen (PNG)",
      "default": false,
      "info": "Si se activa, las imágenes PNG personalizadas heredarán el color de texto de la sección (ideal para iconos de un solo color)."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fondo de Sección",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color de Texto (Títulos y Etiquetas)",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color de Iconos (Acento)",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Superior Desktop",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Inferior Desktop",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 500,
      "step": 10,
      "unit": "px",
      "label": "Padding Izquierdo Desktop",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 500,
      "step": 10,
      "unit": "px",
      "label": "Padding Derecho Desktop",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mb",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Superior Móvil",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mb",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Inferior Móvil",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_left_mb",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Izquierdo Móvil",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_right_mb",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Derecho Móvil",
      "default": 0
    }
  ],
  "blocks": [
    {
      "name": "Icono",
      "type": "icon_block",
      "settings": [
        {
          "type": "select",
          "id": "icon_type",
          "label": "Tipo de Icono",
          "default": "preset",
          "options": [
            { "value": "preset", "label": "Predefinido (Librería)" },
            { "value": "image", "label": "Imagen Personalizada" }
          ]
        },
        {
          "type": "select",
          "id": "preset_icon",
          "label": "Seleccionar Icono",
          "default": "necklace",
          "options": [
            { "value": "necklace", "label": "Collar" },
            { "value": "earrings", "label": "Aros" },
            { "value": "ring", "label": "Anillo" },
            { "value": "bracelet", "label": "Pulsera" },
            { "value": "watch", "label": "Reloj" },
            { "value": "diamond", "label": "Diamante" }
          ]
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Imagen de Icono",
          "info": "Se usa si seleccionas 'Imagen Personalizada' arriba"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Etiqueta",
          "default": "Nombre"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MVD Icons",
      "blocks": [
        { "type": "icon_block", "settings": { "label": "Collares", "preset_icon": "necklace" } },
        { "type": "icon_block", "settings": { "label": "Aros", "preset_icon": "earrings" } },
        { "type": "icon_block", "settings": { "label": "Anillos", "preset_icon": "ring" } },
        { "type": "icon_block", "settings": { "label": "Pulseras", "preset_icon": "bracelet" } }
      ]
    }
  ]
}
{% endschema %}
