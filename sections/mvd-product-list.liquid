<!-- mvd-product-list.liquid -->
{%- liquid
  assign bg_color = section.settings.bgsection
  assign title_size = section.settings.title_size
  assign subtitle_size = section.settings.subtitle_size
-%}

<style>
    #mvd-product-list-{{ section.id }} {
        background-color: {{ bg_color }};
        --title-size: {{ title_size }}px;
        --subtitle-size: {{ subtitle_size }}px;
    }

    {%- if section.settings.nowrap -%}
    .mvd-product-list .swiper-container {
        overflow: visible;
    }
    {%- endif -%}

    .mvd-section-header {
      text-align: {{ section.settings.align-heading }};
      margin-bottom: 40px;
      padding: 0 20px;
    }

    .mvd-subtitle {
      display: block;
      margin-bottom: 12px;
      font-size: var(--subtitle-size);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      font-weight: 500;
      opacity: 0.7;
    }

    .section-title {
      margin: 0;
      font-size: var(--title-size);
      font-weight: 600;
      text-transform: uppercase;
      line-height: 1.2;
      letter-spacing: 0.05em;
    }

    @media screen and (max-width: 1024px) {
      .section-title {
        font-size: calc(var(--title-size) * 0.82);
      }
    }

    @media screen and (max-width: 767px) {
      .section-title {
        font-size: calc(var(--title-size) * 0.68);
      }
      .mvd-subtitle {
        font-size: calc(var(--subtitle-size) * 0.9);
      }
      .mvd-product-list .swiper-container {
          overflow: visible;
      }
      .mvd-product-list .container-p .swiper-slide{
        width:42% !important;
        margin-right:20px !important;
      }
      .mvd-section-header {
        margin-bottom: 25px;
      }
    }

    @media (min-width:750px){
      .productlist-wrapper .swiper-button-prev{
        left: -58px;
      } 
      .productlist-wrapper .swiper-button-next{
        right: -58px;
      } 
    }
    
</style>

<div id="mvd-product-list-{{ section.id }}" class="customstyle{{ section.id }} mvd-product-list" data-aos="{{ section.settings.animation }}">
    {%- render 'style-section' -%}
    <div class="section-block">
      <div class="{{ section.settings.setwidth }}">
        <div class="mvd-section-header">
          {%- if section.settings.subtitle != blank -%}
            <span class="mvd-subtitle">{{ section.settings.subtitle | escape }}</span>
          {%- endif -%}
          {%- if section.settings.title != blank -%}
            <h2 class="section-title">{{ section.settings.title | escape }}</h2>
          {%- endif -%}
          {%- if section.settings.des != blank -%}
            <div class="des-header mt-3 opacity-70">{{ section.settings.des }}</div>
          {%- endif -%}
        </div>
      </div>

      <div class="{{ section.settings.setwidth }} container-p">
        <div class="productlist-wrapper dots-negative swiper-wrapper-{{ section.id }} position-relative">
          <div class="productlist-swiper swiper-container swipercol-{{ section.id }} {% if section.settings.scrollbar %} pb-5 {% endif %}" id="Productlist-{{ section.id }}"
            data-section-id="{{ section.id }}"  
            data-section-type="swipercustom"
            data-perview-desktop="{{ section.settings.perviewDesktop }}"
            data-space-between="{{ section.settings.spaceBetween }}"
            >
            <div class="swiper-wrapper">
              {%- assign collection = collections[section.settings.collection] -%}
              {%- assign limit = section.settings.limit -%}
              {%- if collection != blank -%}
              {%- for product in collection.products limit: limit -%}
              <div class="productlist-item swiper-slide">
                  <div data-aos="{{ section.settings.animation }}"  data-aos-delay="{{ forloop.index | times: 100 }}">
                    {%- render 'product-card', product: product -%}
                  </div>
              </div>
              {%- endfor -%}
              {%- else -%}
              {%- for i in (1..limit) -%}
              <div class="productlist-item swiper-slide">
                <div data-aos="{{ section.settings.animation }}"  data-aos-delay="{{ forloop.index | times: 100 }}">
                  {%- render 'product-grid-blank' -%}
                </div>
              </div>
              {%- endfor -%}
              {%- endif -%}
              </div>
              
              {%- if section.settings.scrollbar -%}
              <div class="swiper-scrollbar"></div>
              {%- endif -%}
          </div>
          {%- if section.settings.arrows -%}
              <div class="swiper-button-prev"></div>
              <div class="swiper-button-next"></div>
          {%- endif -%}
      </div>
    </div>
  </div>
</div>


{%- if section.settings.animation != blank -%}
  <script>
    (function(){
      var sectionEl = document.getElementById('shopify-section-{{ section.id }}');
      if (sectionEl) {
        {% if section.settings.animation == 'parallax' %}
          sectionEl.setAttribute('data-mvd-premium-parallax', 'true');
        {% elsif section.settings.animation == 'sticky-reveal' %}
          sectionEl.setAttribute('data-mvd-sticky-reveal', 'true');
        {% else %}
          sectionEl.setAttribute('data-aos', '{{ section.settings.animation }}');
        {% endif %}
      }
    })();
  </script>
{%- endif -%}

{% schema %}

{
  "name": "MVD Product List",
  "class": "index-section",
  "settings": [
    {
      "type": "select",
      "id": "animation",
      "label": "Seleccionar Animación",
      "default": "fade-up",
      "options": [
        {
          "value": "",
          "label": "None"
        },
        {
          "value": "fade",
          "label": "Fade"
        },
        {
          "value": "fade-up",
          "label": "Fade Up"
        },
        {
          "value": "fade-down",
          "label": "Fade Down"
        },
        {
          "value": "zoom-in",
          "label": "Zoom In"
        },
        {
          "value": "zoom-out",
          "label": "Zoom Out"
        },
        {
          "value": "parallax",
          "label": "Parallax Scrolling (Slide Over)"
        },
        {
          "value": "sticky-reveal",
          "label": "Sticky Footer Reveal (Curtain)"
        }
      ]
    },
    {
      "type": "select",
      "id": "setwidth",
      "label": "Ancho del contenedor",
      "default": "container",
      "options": [
        {
          "value": "container",
          "label": "Box"
        },
        {
          "value": "container-fluid",
          "label": "Container Fluid"
        },
        {
          "value": "full",
          "label": "Full"
        }
      ]
    },
    {
      "type": "color",
      "id": "bgsection",
      "label": "Background Section",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Tipografía Premium"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "The Collection"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Product list"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Tamaño del Título (Desktop)",
      "default": 36
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Tamaño del Subtítulo (Desktop)",
      "default": 13
    },
    {
      "type": "textarea",
      "id": "des",
      "label": "Descripción / HTML"
    },
    {
      "type": "select",
      "id": "align-heading",
      "label": "Alineación del Texto",
      "default": "center",
      "options": [
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "header",
      "content": "Configuración de Colección"
    },
    {
      "label": "Colección",
      "id": "collection",
      "type": "collection"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 3,
      "max": 30,
      "step": 1,
      "label": "Límite de productos",
      "default": 10
    },
    {
      "type": "range",
      "id": "perviewDesktop",
      "label": "Productos por Vista (Desktop)",
      "max": 6,
      "min": 1,
      "step": 1,
      "unit": " c",
      "default": 3
    },
    {
      "type": "range",
      "id": "spaceBetween",
      "label": "Espacio entre productos",
      "max": 40,
      "min": 0,
      "step": 1,
      "unit": " sp",
      "default": 30
    },
    {
      "type": "header",
      "content": "Controles de Slider"
    },
    {
      "type": "checkbox",
      "id": "nowrap",
      "label": "Permitir asomarse (Mobile Peek)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "arrows",
      "label": "Mostrar Flechas",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "scrollbar",
      "label": "Mostrar Barra de Scroll",
      "default": false
    },
    {
      "type": "header",
      "content": "Espaciado de Sección"
    },
    {
      "type": "text",
      "id": "paddingsection",
      "label": "Padding Desktop",
      "default": "50px 0px 50px 0px",
      "info": "Padding: Top Right Bottom Left"
    },
    {
      "type": "text",
      "id": "paddingmobile",
      "label": "Padding Mobile",
      "default": "40px 0px 40px 0px",
      "info": "Padding: Top Right Bottom Left"
    }
  ],
  "presets": [
    {
      "name": "MVD Product List",
      "category": "Collection"
    }
  ]
}

{% endschema %}
