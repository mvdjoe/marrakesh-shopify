<div class="customstyle{{ section.id }} " data-aos="{{ section.settings.animation }}" >
    {%- render 'style-section' -%}
    <div class="{{ section.settings.setwidth }}">
    {%- for block in section.blocks -%}
        {% render block %}
    {%- endfor -%}
    </div>
</div>


{%- if section.settings.animation != blank -%}
  <script>
    (function(){
      var sectionEl = document.getElementById('shopify-section-{{ section.id }}');
      if (sectionEl) {
        {% if section.settings.animation == 'parallax' %}
          sectionEl.setAttribute('data-mvd-premium-parallax', 'true');
        {% elsif section.settings.animation == 'sticky-reveal' %}
          sectionEl.setAttribute('data-mvd-sticky-reveal', 'true');
        {% else %}
          sectionEl.setAttribute('data-aos', '{{ section.settings.animation }}');
        {% endif %}
      }
    })();
  </script>
{%- endif -%}

{% schema %}

{
  "name": "Apps",
  "tag": "section",
  "class": "index-section",
  "settings": [
    {
      "type": "select",
      "id": "animation",
      "label": "Seleccionar Animación",
      "default": "fade-up",
      "options": [
        {
          "value": "",
          "label": "None"
        },
        {
          "value": "fade",
          "label": "Fade"
        },
        {
          "value": "fade-up",
          "label": "Fade Up"
        },
        {
          "value": "fade-down",
          "label": "Fade Down"
        },
        {
          "value": "zoom-in",
          "label": "Zoom In"
        },
        {
          "value": "zoom-out",
          "label": "Zoom Out"
        },
        {
          "value": "parallax",
          "label": "Parallax Scrolling (Slide Over)"
        },
        {
          "value": "sticky-reveal",
          "label": "Sticky Footer Reveal (Curtain)"
        }
      ]
    },
    {
      "type": "text",
      "id": "paddingsection",
      "label": "Section padding",
      "default": "0px 0px 0px 0px",
      "info": "Padding: Top Right Bottom Left"
    },
    {
      "type": "text",
      "id": "paddingmobile",
      "label": "Padding Section Mobile",
      "default": "60px 0px 60px 0px",
      "info": "Padding: Top Right Bottom Left"
    },
    {
      "type": "text",
      "id": "marginsection",
      "label": "Margin Section",
      "default": "0px 0px 0px 0px",
      "info": "Margin: Top Right Bottom Left"
    },
    {
      "type": "text",
      "id": "marginmobile",
      "label": "Margin Mobile",
      "default": "0px 0px 0px 0px",
      "info": "Margin: Top Right Bottom Left"
    },
    {
      "type": "color",
      "id": "bgsection",
      "label": "Background Section",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "apps"
    }
  ]
}

{% endschema %}
