{%- liquid
  assign bg_color = section.settings.bg_color | default: 'transparent'
  assign text_color = section.settings.text_color | default: '#000000'
  assign username = section.settings.username | remove: '@'
  assign insta_url = 'https://www.instagram.com/' | append: username
-%}

<style>
  :root {
    --mvd-insta-cols-desktop: {{ section.settings.cols_desktop }};
    --mvd-insta-cols-tablet: {{ section.settings.cols_desktop | minus: 1 | at_least: 2 }};
    --mvd-insta-cols-mobile: {{ section.settings.cols_mobile }};
    --mvd-insta-height-desktop: {{ section.settings.height_desktop }}px;
    --mvd-insta-height-mobile: {{ section.settings.height_mobile }}px;
    --mvd-insta-gap: {{ section.settings.gap }}px;
  }

  .mvd-insta-{{ section.id }} {
    background-color: {{ bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    color: {{ text_color }};
    overflow: hidden;
  }

  .mvd-insta-container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }
  
  .mvd-insta-full-width .mvd-insta-container {
    max-width: 100%;
    padding: 0;
  }

  .mvd-insta-header {
    text-align: {{ section.settings.align_heading }};
    margin-bottom: 25px;
  }

  .mvd-insta-username-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-transform: uppercase;
    font-size: 13px;
    letter-spacing: 0.1em;
    font-weight: 600;
    color: inherit;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .mvd-insta-username-link:hover {
    opacity: 0.7;
    text-decoration: none;
    color: inherit;
  }

  .mvd-insta-username-link svg {
    width: 16px;
    height: 16px;
  }

  /* Grid */
  .mvd-insta-grid {
    display: grid;
    grid-template-columns: repeat(var(--mvd-insta-cols-desktop), 1fr);
    gap: var(--mvd-insta-gap);
  }

  .mvd-insta-item {
    position: relative;
    height: var(--mvd-insta-height-desktop);
    overflow: hidden;
    background: #f4f4f4;
    cursor: pointer;
  }

  .mvd-insta-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mvd-insta-item:hover img {
    transform: scale(1.05);
  }

  .mvd-insta-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .mvd-insta-item:hover .mvd-insta-overlay {
    opacity: 1;
  }

  .mvd-insta-icon {
    width: 30px;
    height: 30px;
    color: white;
  }

  @media (max-width: 991px) {
    .mvd-insta-grid {
      grid-template-columns: repeat(var(--mvd-insta-cols-tablet), 1fr);
    }
  }

  @media (max-width: 767px) {
    .mvd-insta-grid {
      grid-template-columns: repeat(var(--mvd-insta-cols-mobile), 1fr);
    }
    .mvd-insta-item {
      height: var(--mvd-insta-height-mobile);
    }
    .mvd-insta-header {
      margin-bottom: 20px;
    }
  }
</style>

<div class="mvd-insta-{{ section.id }} {% if section.settings.full_width %}mvd-insta-full-width{% endif %}" id="MvdInsta-{{ section.id }}">
  <div class="mvd-insta-container">
    {%- if username != blank -%}
      <div class="mvd-insta-header">
        <a href="{{ insta_url }}" target="_blank" class="mvd-insta-username-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          @{{ username }}
        </a>
      </div>
    {%- endif -%}

    <div class="mvd-insta-grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign image = block.settings.image
          assign link = block.settings.link
        -%}
        <a href="{{ link | default: insta_url }}" target="_blank" class="mvd-insta-item" {{ block.shopify_attributes }}>
          {%- if image != blank -%}
            <img src="{{ image | img_url: '800x' }}" alt="Instagram Content" loading="lazy">
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
          
          <div class="mvd-insta-overlay">
            <svg class="mvd-insta-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}{
  "name": "MVD Instagram",
  "settings": [
    {
      "type": "text",
      "id": "username",
      "label": "Usuario de Instagram",
      "default": "marrakeshchile",
      "info": "Sin el símbolo @"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Ancho completo",
      "default": false
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 2000,
      "step": 50,
      "unit": "px",
      "label": "Ancho máximo (si no es full width)",
      "default": 1400
    },
    {
      "type": "select",
      "id": "align_heading",
      "label": "Alineación de usuario",
      "default": "center",
      "options": [
        { "value": "left", "label": "Izquierda" },
        { "value": "center", "label": "Centro" }
      ]
    },
    {
      "type": "header",
      "content": "Ajustes de Grid (Cuadrícula)"
    },
    {
      "type": "range",
      "id": "cols_desktop",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Columnas Desktop",
      "default": 6
    },
    {
      "type": "range",
      "id": "cols_mobile",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Columnas Mobile",
      "default": 3
    },
    {
      "type": "range",
      "id": "height_desktop",
      "min": 100,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Altura item Desktop",
      "default": 250
    },
    {
      "type": "range",
      "id": "height_mobile",
      "min": 100,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Altura item Mobile",
      "default": 150
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Espacio entre items",
      "default": 4
    },
    {
      "type": "header",
      "content": "Diseño y Colores"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color de texto",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Espaciado (Padding)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Superior",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Inferior",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Imagen Instagram",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen / Miniatura"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link directo al post (opcional)",
          "info": "Si se deja vacío, enlazará al perfil general."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MVD Instagram",
      "blocks": [
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}{% endschema %}