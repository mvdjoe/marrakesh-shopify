<style>
  .mvd-instagram-section {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: {{ section.settings.padding_left }}px;
    padding-right: {{ section.settings.padding_right }}px;
  }
  
  .mvd-instagram-container {
    max-width: 1200px;
    margin: 0 auto;
    padding-left: 15px;
    padding-right: 15px;
  }
  
  .mvd-instagram-box {
    max-width: 900px;
    margin: 0 auto;
    padding: 20px;
    border: 1px solid #ddd;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }
  
  .mvd-instagram-full-width {
    padding-left: 0;
    padding-right: 0;
  }
</style>

{% if section.settings.instagram_embed_code != blank %}
  <div class="mvd-instagram-section">
    <div class="{% case section.settings.layout %}{% when 'container' %}mvd-instagram-container{% when 'box' %}mvd-instagram-box{% else %}mvd-instagram-full-width{% endcase %}">
      {% if section.settings.heading != blank %}
        <h2 style="text-align:center;">{{ section.settings.heading }}</h2>
      {% endif %}
      <div class="mvd-instagram-feed">
        {{ section.settings.instagram_embed_code | raw }}
      </div>
    </div>
  </div>
{% endif %}

{% schema %}{
  "name": "MVD Instagram Feed",
  "tag": "section",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Ancho de la sección",
      "default": "container",
      "options": [
        {
          "value": "container",
          "label": "Ancho fijo (Container)"
        },
        {
          "value": "full-width",
          "label": "Ancho completo (Full width)"
        },
        {
          "value": "box",
          "label": "Caja (Box)"
        }
      ]
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título de la sección",
      "default": "Síguenos en Instagram"
    },
    {
      "type": "html",
      "id": "instagram_embed_code",
      "label": "Código de inserción de Instagram",
      "info": "Pega aquí el código de inserción de un servicio como LightWidget o SnapWidget para mostrar tu feed de Instagram."
    },
    {
      "type": "header",
      "content": "Espaciado de la sección"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Espacio superior (Padding Top)",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Espacio inferior (Padding Bottom)",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Espacio izquierdo (Padding Left)",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Espacio derecho (Padding Right)",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "MVD Instagram Feed",
      "category": "Social Media"
    }
  ]
}{% endschema %}