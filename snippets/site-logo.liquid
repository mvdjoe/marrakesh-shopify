{%- liquid
  assign logo_max_width = section.settings.logo_max_width
-%}

<style>.site-header__logo img {width: {{ logo_max_width | append: 'px' }};}.site-header__logo.has-logo{font-size: 0;line-height: 0;}.site-header__logo.has-logo a{font-size: 0;line-height: 0;}</style>

{%- if template.name == 'index' -%}
  {%- comment %} HOME PAGE - Show white logo {% endcomment -%}
  {%- assign home_logo = section.settings.logo_home -%}
  {%- if home_logo == blank -%}
    {%- assign home_logo = section.settings.logo_white -%}
  {%- endif -%}
  {%- if home_logo == blank -%}
    {%- assign home_logo = settings.logo_white -%}
  {%- endif -%}
  <h1 class="site-header__logo has-logo" itemscope itemtype="http://schema.org/Organization">
    <a href="{{ routes.root_url }}" itemprop="url" class="site-header__logo-link">
      {%- if home_logo != blank -%}
        {%- assign maxlogo = logo_max_width | times: 2 -%}
        {{ home_logo | image_url: width: maxlogo | image_tag:
          class: 'logo-home',
          widths: '50, 100, 150, 200, 250, 300, 400, 500',
          width: logo_max_width,
          alt: shop.name
        }}
      {%- else -%}
        <span>{{ shop.name }}</span>
      {%- endif -%}
    </a>
  </h1>
{%- else -%}
  {%- comment %} OTHER PAGES - Show general logo {% endcomment -%}
  <div class="site-header__logo h1" itemscope itemtype="http://schema.org/Organization">
    {%- if section.settings.logo_general != blank or section.settings.logo != blank -%}
      <a href="{{ routes.root_url }}" itemprop="url" class="site-header__logo-link">
        {%- assign general_logo = section.settings.logo_general | default: section.settings.logo -%}
        {%- assign maxlogo = logo_max_width | times: 2 -%}
        {{ general_logo | image_url: width: maxlogo | image_tag:
          class: 'logo-general',
          widths: '50, 100, 150, 200, 250, 300, 400, 500',
          height: general_logo.height,
          width: general_logo.width,
          alt: shop.name
        }}
      </a>
    {%- else -%}
      {%- assign shop_name_length = shop.name.size -%}
      <a href="/" itemprop="url" {% if shop_name_length > 10 %} class="site-header__shop-name--small"{% endif %}>{{ shop.name }}</a>
    {%- endif -%}
  </div>
{%- endif -%}